// Copy this file to `Secrets.xcconfig` (which is gitignored) and fill in your value.
// Secrets.xcconfig is included by Spool.xcconfig and overrides its defaults, so your
// personal identifiers never get committed.
//
// Find your 10-character Apple Development Team ID:
//   security find-identity -p codesigning -v
// → the value in parentheses, e.g. "Apple Development: you@example.com (A1B2C3D4E5)"

DEVELOPMENT_TEAM = YOUR_TEAM_ID

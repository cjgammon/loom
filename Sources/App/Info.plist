<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Spool</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<!-- Menu-bar only app: no Dock icon. -->
	<key>LSUIElement</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Spool records your webcam for the camera bubble in your screen recordings.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Spool records your microphone narration in your screen recordings.</string>
	<!-- Custom URL scheme used for the Frame.io / Adobe IMS OAuth redirect. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.cjgammon.Spool.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>spool</string>
			</array>
		</dict>
	</array>
	<!--
	  Adobe / Frame.io OAuth credentials are intentionally NOT committed here. Enter your
	  Client ID and Redirect URI in Spool → Settings (persisted per-machine), or inject
	  SPOOL_ADOBE_CLIENT_ID / SPOOL_REDIRECT_URI via build settings locally.
	-->
</dict>
</plist>
